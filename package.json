{
  "name": "diamond-soul-downloader",
  "version": "0.2.0",
  "description": "Diamond Soul Downloader - Install AI Skills from IPFS",
  "main": "lib/config.js",
  "bin": {
    "dsoul": "./bin/dsoul.js"
  },
  "scripts": {
    "start": "node bin/dsoul.js webstart",
    "dev": "node bin/dsoul.js webstart",
    "test": "node scripts/test-cli.js",
    "test:cli": "node scripts/test-cli.js",
    "dist:win": "node scripts/pkg-build.js win",
    "dist:mac": "node scripts/pkg-build.js mac",
    "dist:wsl": "node scripts/pkg-build.js linux",
    "dist:linux": "node scripts/pkg-build.js linux",
    "dist:linux:wsl": "node scripts/pkg-build.js linux",
    "dist": "npm run dist:win && npm run dist:mac && npm run dist:linux:wsl",
    "dist:bun-win": "bun build --compile --target=bun-windows-x64 --external react-devtools-core bin/dsoul.js --outfile dist/dsoul-bun.exe",
    "dist:bun-mac": "bun build --compile --target=bun-darwin-arm64 --external react-devtools-core bin/dsoul.js --outfile dist/dsoul-bun-mac",
    "dist:bun-linux": "bun build --compile --target=bun-linux-x64 --external react-devtools-core bin/dsoul.js --outfile dist/dsoul-bun",
    "dist:bun": "npm run dist:bun-win && npm run dist:bun-mac && npm run dist:bun-linux",
    "postdist:win": "node scripts/copy-prebuilds.js",
    "postdist": "node scripts/copy-prebuilds.js && node scripts/cleanup-dist.js",
    "prepdeploy": "node scripts/prepdeploy.js"
  },
  "pkg": {
    "assets": [
      "package.json",
      "node_modules/**/*.wasm",
      "node_modules/**/*.json",
      "packages/bundles.js"
    ],
    "scripts": [
      "bin/**/*.js",
      "cli/**/*.js",
      "lib/**/*.js",
      "server/**/*.js"
    ]
  },
  "keywords": [
    "ipfs",
    "cli",
    "cid",
    "skills"
  ],
  "author": "Nick <nick@chainletter.io>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "cli/",
    "lib/",
    "server/",
    "public/",
    "LICENSE"
  ],
  "dependencies": {
    "archiver": "^7.0.1",
    "bun": "^1.3.10",
    "diff": "^5.2.0",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ipfs-only-hash": "^2.0.1",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "yauzl": "^2.10.0"
  },
  "optionalDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.16.1"
  }
}
